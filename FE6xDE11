local function httpGet(url)
    local function finish(body)
        if shouldPatchHttpUrl(url) then
            return patchRayfieldSource(body)
        end
        return body
    end
    if syn and syn.request then
        local ok, res = pcall(syn.request, {Url = url, Method = "GET"})
        if ok and res and res.Body and #res.Body > 100 then
            return finish(res.Body)
        end
    end
    if http and http.request then
        local ok, res = pcall(http.request, {Url = url, Method = "GET"})
        if ok and res and res.Body and #res.Body > 100 then
            return finish(res.Body)
        end
    end
    local ok, body = pcall(function() return game:HttpGet(url) end)
    if ok and type(body) == "string" and #body > 100 then
        return finish(body)
    end
    error("Could not HttpGet — use MacSploit")
end

local function loadBloodyHub(attempt)
    attempt = attempt or 1
    local ok, err = pcall(function()
        local src = httpGet(BLOODY_URL)
        local fn, compileErr = loadstring(src)
        if not fn then
            error("Failed to compile Bloody: " .. tostring(compileErr))
        end
        fn()
    end)
    if not ok then
        warn("[FE6 x DE11] Bloody load failed (attempt " .. attempt .. "):", err)
        if attempt < 2 then
            task.wait(1.5)
            return loadBloodyHub(attempt + 1)
        end
        pcall(function()
            StarterGui:SetCore("SendNotification", {
                Title = CHAT_NAME,
                Text = "Load failed - re-execute script",
                Duration = 6,
            })
        end)
        cleanupDevilArtifacts()
        ensureHubVisible()
    else
        hubLoaded = true
        hijackRayfieldTheme()
        for _, gui in ipairs(PlayerGui:GetChildren()) do registerHubGui(gui) end
        sweepHubTheme()
        ensureHubVisible()
        runInitialHubPasses()
        task.defer(cleanupDevilArtifacts)
        pcall(function()
            StarterGui:SetCore("SendNotification", {
                Title = CHAT_NAME,
                Text = LOAD_POPUP,
                Duration = 6,
            })
        end)
        pcall(function()
            StarterGui:SetCore("ChatMakeSystemMessage", {
                Text = CHAT_NAME .. " loaded perfectly.",
                Color = THEME.accent,
                Font = Enum.Font.GothamBold,
                FontSize = Enum.FontSize.Size18,
            })
        end)
    end
    return ok
end

