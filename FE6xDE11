local function hijackRayfieldTheme()
    pcall(function()
        if not getgenv then return end
        for _, key in ipairs({ "Rayfield", "RayfieldLibrary", "Library" }) do
            local lib = getgenv()[key]
            if type(lib) == "table" and type(lib.Theme) == "table" then
                for _, themeTable in pairs(lib.Theme) do
                    if type(themeTable) == "table" then
                        for k, v in pairs(RAYFIELD_PURPLE) do
                            themeTable[k] = v
                        end
                    end
                end
            end
        end
    end)
end

local function paintGuiObject(inst, inventoryMode)
    pcall(function()
        if inst:IsA("GuiObject") then
            inst.BackgroundColor3 = remapColor(inst.BackgroundColor3)
            inst.BorderColor3 = remapColor(inst.BorderColor3)
            if inst:IsA("TextLabel") or inst:IsA("TextButton") or inst:IsA("TextBox") then
                inst.TextColor3 = inventoryMode and Color3.fromRGB(245, 240, 255) or remapColor(inst.TextColor3)
            end
            if inst:IsA("ImageLabel") or inst:IsA("ImageButton") then
                inst.ImageColor3 = inventoryMode and THEME.accentLight or remapColor(inst.ImageColor3)
            end
        end
        if inst:IsA("UIStroke") then
            inst.Color = inventoryMode and THEME.accentLight or remapColor(inst.Color)
        end
        if inst:IsA("UIGradient") then
            inst.Color = remapColor(inst.Color)
        end
    end)
end

local function paintHubGui(gui)
    if not gui or not gui.Parent then return end
    for _, inst in ipairs(gui:GetDescendants()) do
        paintGuiObject(inst, false)
    end
end

local function paintInventoryGui(gui)
    if not gui or not gui.Parent then return end
    for _, inst in ipairs(gui:GetDescendants()) do
        paintGuiObject(inst, true)
    end
end

local function sweepHubTheme()
    for _, gui in ipairs(PlayerGui:GetChildren()) do
        registerHubGui(gui)
    end
    for gui, _ in pairs(registeredHubGuis) do
        if gui.Parent then
            paintHubGui(gui)
        else
            registeredHubGuis[gui] = nil
        end
    end
    hijackRayfieldTheme()
end

local function refreshInventoryPurple()
    if not inventoryPurpleOn then return end
    for _, gui in ipairs(PlayerGui:GetChildren()) do
        if registerInventoryGui(gui) then
            paintInventoryGui(gui)
        end
    end
end

local function scheduleSweep(delay)
