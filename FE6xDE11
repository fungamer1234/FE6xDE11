local function findMainHubGui()
    for _, gui in ipairs(PlayerGui:GetChildren()) do
        if gui:IsA("ScreenGui") and not OUR_OVERLAY_NAMES[gui.Name] then
            local n = gui.Name:lower()
            if n:find("rayfield", 1, true) or n:find("bloody", 1, true) or n:find("main", 1, true) then
                return gui
            end
            for _, child in ipairs(gui:GetDescendants()) do
                if child:IsA("TextLabel") or child:IsA("TextButton") then
                    local t = child.Text
                    if t and (t:lower():find("bloody", 1, true) or t == HUB_NAME or t == WINDOW_TITLE) then
                        return gui
                    end
                end
            end
        end
    end
    for _, gui in ipairs(PlayerGui:GetChildren()) do
        if gui:IsA("ScreenGui") and gui.Enabled and not OUR_OVERLAY_NAMES[gui.Name] then
            if gui:FindFirstChildWhichIsA("Frame", true) then
                return gui
            end
        end
    end
    return nil
end

local function toggleHubMenu()
    local hub = findMainHubGui()
    if hub then
        hub.Enabled = not hub.Enabled
        return true
    end
    for _, gui in ipairs(PlayerGui:GetChildren()) do
        if gui:IsA("ScreenGui") and not OUR_OVERLAY_NAMES[gui.Name] then
            local main = gui:FindFirstChild("Main", true) or gui:FindFirstChild("MainFrame", true)
            if main and main:IsA("GuiObject") then
                main.Visible = not main.Visible
                return true
            end
        end
    end
    return false
end

