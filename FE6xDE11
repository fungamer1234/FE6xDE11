local function ensureHubVisible()
    pcall(function()
        for _, gui in ipairs(PlayerGui:GetChildren()) do
            registerHubGui(gui)
            if registeredHubGuis[gui] then
                gui.Enabled = true
                local main = gui:FindFirstChild("Main", true) or gui:FindFirstChild("MainFrame", true)
                if main and main:IsA("GuiObject") then
                    main.Visible = true
                end
            end
        end
    end)
end

