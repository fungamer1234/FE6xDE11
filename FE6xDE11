end

local function shouldRebrandText(str)
    if type(str) ~= "string" then return false end
    if TAB_WHITELIST[str] then return false end
    local lower = str:lower()
    if lower:find("bloody", 1, true) then return true end
    if lower:find("tokra", 1, true) then return true end
    if lower:find("made by", 1, true) and lower:find("bloody", 1, true) then return true end
    if (lower:find("premium", 1, true) or lower:find("crack", 1, true)) and #str > 8 then return true end
    if lower:find("destroyer", 1, true) and lower:find("bloody", 1, true) then return true end
    return false
end

local function rebrandText(str)
    if type(str) ~= "string" then return str end
    if TAB_WHITELIST[str] then return str end
    if not shouldRebrandText(str) then return str end

    local out = str
    out = out:gsub("[Mm]ade%s+[Bb]y%s+[Bb]loody[%s%p]*", CREDIT_TEXT)
    out = out:gsub("[Bb]y%s+[Bb]loody[%s%p]*", CREDIT_TEXT)
    out = out:gsub("[Bb]loody%s*[%-%s]*[Pp]remium%s*[%-%s]*[Cc]rack[%s%p]*", HUB_NAME)
    out = out:gsub("[Bb]loody%s*[%-%s]*[Pp]remium[%s%p]*", HUB_NAME)
    out = out:gsub("[Bb]loody%s*[%-%s]*[Hh]ub[%s%p]*", HUB_NAME)
    out = out:gsub("[Bb]loody[%s%p]*", HUB_NAME)
    out = out:gsub("[Tt]okra[%s%p]*", CHAT_NAME)

    if out:find("[Pp]remium", 1) or out:find("[Cc]rack", 1) then
        if not TAB_WHITELIST[out] then
            out = out:gsub("[%s%-%[%]%(%)]*[Pp]remium[%s%p]*", " ")
            out = out:gsub("[%s%-%[%]%(%)]*[Cc]rack[%s%p]*", " ")
            out = out:gsub("%s+", " "):gsub("^%s+", ""):gsub("%s+$", "")
        end
    end

    if out:lower():find("bloody", 1, true) or out:lower():find("premium", 1, true) or out:lower():find("tokra", 1, true) then
        if out:find("💀") or #out > 14 then
            out = WINDOW_TITLE
        else
            out = HUB_NAME
        end
    end

    if out:lower():find("made by", 1, true) or out:lower():find("by bloody", 1, true) then
        out = CREDIT_TEXT
    end

    return out
end

local function remapColor(color)
    if typeof(color) ~= "Color3" then return color end
    local r = math.floor(color.R * 255 + 0.5)
    local g = math.floor(color.G * 255 + 0.5)
    local b = math.floor(color.B * 255 + 0.5)

    if r > g + 8 and r > b + 8 and r > 80 then
        return THEME.accent
    end
    if r > 90 and g < 50 and b < 70 and r > g + 40 then
        return THEME.accent
    end
    if r >= 140 and g <= 90 and b <= 90 and r > g + 25 then
        return THEME.accent
    end
    if r >= 200 and g <= 120 and b <= 120 then
        return THEME.accentLight
    end
    if r <= 25 and g <= 25 and b <= 30 then
        return THEME.bg
    end
    if r <= 45 and g <= 35 and b <= 55 and r > 15 then
        return THEME.panel
    end
    if r <= 65 and g <= 50 and b <= 80 then
        return THEME.card
    end
    if r == 0 and g == 255 and b == 255 then
        return THEME.accent
    end
    if r == 255 and g == 255 and b == 255 then
        return color
    end
    if r < 15 and g < 10 and b < 20 then
        return THEME.bg
    end

    return color
end

local function shouldPatchHttpUrl(url)
    if type(url) ~= "string" then return false end
    local lower = url:lower()
    if lower:find("bloody", 1, true) or lower:find("youhateme", 1, true) then return false end
    if lower:find(".luau", 1, true) or lower:find(".lua", 1, true) then
        if not lower:find("rayfield", 1, true) and not lower:find("sirius", 1, true) then
            return false
        end
    end
    return lower:find("rayfield", 1, true) ~= nil
        or lower:find("sirius.menu", 1, true) ~= nil
end

local function patchRayfieldSource(src)
    if type(src) ~= "string" then return src end
    if #src > 200000 then return src end
    local lower = src:lower()
    if not (lower:find("rayfield", 1, true) and lower:find("createwindow", 1, true)) then
        return src
    end

    local reps = {
        ["Color3.fromRGB(0, 255, 255)"]   = "Color3.fromRGB(98, 56, 198)",
        ["Color3.fromRGB(0, 255, 255.0)"] = "Color3.fromRGB(98, 56, 198)",
        ["Color3.fromRGB(25, 25, 25)"]    = "Color3.fromRGB(10, 6, 22)",
        ["Color3.fromRGB(20, 20, 20)"]    = "Color3.fromRGB(10, 6, 22)",
        ["Color3.fromRGB(30, 30, 30)"]    = "Color3.fromRGB(20, 12, 42)",
        ["Color3.fromRGB(35, 35, 35)"]    = "Color3.fromRGB(20, 12, 42)",
        ["Color3.fromRGB(40, 40, 40)"]    = "Color3.fromRGB(30, 18, 58)",
        ["Color3.fromRGB(45, 45, 45)"]    = "Color3.fromRGB(30, 18, 58)",
        ["Color3.fromRGB(255, 0, 0)"]     = "Color3.fromRGB(98, 56, 198)",
        ["Color3.fromRGB(200, 0, 0)"]     = "Color3.fromRGB(98, 56, 198)",
        ["Color3.fromRGB(180, 0, 0)"]     = "Color3.fromRGB(98, 56, 198)",
        ["Color3.fromRGB(150, 0, 0)"]     = "Color3.fromRGB(98, 56, 198)",
        ["Color3.fromRGB(255, 50, 50)"]   = "Color3.fromRGB(98, 56, 198)",
        ["Color3.fromRGB(255, 70, 70)"]   = "Color3.fromRGB(130, 90, 220)",
        ["ToggleEnabled = Color3.fromRGB(255, 0, 0)"] = "ToggleEnabled = Color3.fromRGB(98, 56, 198)",
        ["TabBackgroundSelected = Color3.fromRGB(255, 0, 0)"] = "TabBackgroundSelected = Color3.fromRGB(98, 56, 198)",
        ["SliderProgress = Color3.fromRGB(255, 0, 0)"] = "SliderProgress = Color3.fromRGB(98, 56, 198)",
        ["Accent = Color3"]               = "Accent = Color3",
        ['"Bloody"']                      = '"' .. HUB_NAME .. '"',
        ["'Bloody'"]                      = "'" .. HUB_NAME .. "'",
        ["Bloody Hub"]                    = HUB_NAME,
        ["Bloody Premium"]                = HUB_NAME,
    }

    for old, new in pairs(reps) do
        src = src:gsub(old, new)
    end

    src = src:gsub('Title%s*=%s*"(.-)"', function(t)
        if t:lower():find("bloody", 1, true) or t:lower():find("premium", 1, true) then
            return 'Title = "' .. WINDOW_TITLE .. '"'
        end
        return 'Title = "' .. t .. '"'
    end)

    return src
end

local function isOurOverlay(inst)
    if not inst or not inst:IsA("GuiObject") then return false end
    local p = inst
    while p do
        if p:IsA("ScreenGui") and OUR_OVERLAY_NAMES[p.Name] then
            return true
        end
        p = p.Parent
    end
    return false
end

local function isChatOrSystemGui(gui)
    if not gui or not gui:IsA("ScreenGui") then return false end
    return CHAT_GUI_NAMES[gui.Name] == true
end

local function nameHintsInventory(name)
    local n = name:lower()
    for _, hint in ipairs(INVENTORY_NAME_HINTS) do
        if n:find(hint, 1, true) then return true end
    end
    return false
end

local function guiHasHubTabs(gui)
    for _, d in ipairs(gui:GetDescendants()) do
        if (d:IsA("TextButton") or d:IsA("TextLabel")) and TAB_WHITELIST[d.Text] then
            return true
        end
    end
    return false
end

local function registerHubGui(gui)
    if not gui or not gui:IsA("ScreenGui") or isOurOverlay(gui) then return end
    if nameHintsInventory(gui.Name) then return end
    local n = gui.Name:lower()
    if n:find("rayfield", 1, true) or n:find("bloody", 1, true) or guiHasHubTabs(gui) then
        registeredHubGuis[gui] = true
    end
end

local function isHubGui(inst)
    if not inst or not inst:IsA("GuiObject") or isOurOverlay(inst) then return false end
    local n = inst.Name:lower()
    if n:find("rayfield", 1, true) or n:find("bloody", 1, true) then return true end
    local p = inst.Parent
    while p do
        if p:IsA("ScreenGui") then
            if registeredHubGuis[p] then return true end
            registerHubGui(p)
            return registeredHubGuis[p] == true
        end
        p = p.Parent
    end
    return false
end

local function isInventoryGui(gui)
    if not gui or not gui:IsA("ScreenGui") then return false end
    if isOurOverlay(gui) or isChatOrSystemGui(gui) or registeredHubGuis[gui] then return false end
    local n = gui.Name:lower()
    if n:find("rayfield", 1, true) or n:find("bloody", 1, true) then return false end
    if guiHasHubTabs(gui) then return false end
    return nameHintsInventory(gui.Name)
end

local function registerInventoryGui(gui)
    if isInventoryGui(gui) then
        registeredInventoryGuis[gui] = true
        return true
    end
    return false
end

local function isInventoryElement(inst)
    if not inventoryPurpleOn or not inst or not inst:IsA("GuiObject") or isOurOverlay(inst) then
        return false
    end
    local p = inst.Parent
    while p do
        if p:IsA("ScreenGui") then
            if registeredInventoryGuis[p] then return true end
            if registerInventoryGui(p) then return true end
            return false
        end
        p = p.Parent
    end
    return false
end

